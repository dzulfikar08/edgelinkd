# =============================================================================
# rust-red Dockerfile.slim — minimal variant
# Core-only build: no network/storage/industrial nodes, smaller binary
# =============================================================================
# Build:
#   docker build -f Dockerfile.slim -t rust-red:slim .
# Run:
#   docker run -p 1880:1880 -p 1883:1883 -v rust-red-data:/data rust-red:slim
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Build the statically-linked binary with musl (core only)
# ---------------------------------------------------------------------------
FROM rust:1.82-slim AS builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        musl-tools \
        pkg-config \
        git \
    && rm -rf /var/lib/apt/lists/*

RUN rustup target add x86_64-unknown-linux-musl

WORKDIR /usr/src/rust-red

COPY Cargo.toml Cargo.lock build.rs ./
COPY crates ./crates
COPY node-plugins ./node-plugins
COPY 3rd-party ./3rd-party
COPY src ./src

# Build with --features core only — no JS engine, no network/storage/industrial
# nodes. This produces a significantly smaller binary.
RUN cargo build --features core --release --target x86_64-unknown-linux-musl

RUN ls -lh target/x86_64-unknown-linux-musl/release/rust-red

# ---------------------------------------------------------------------------
# Stage 2: Minimal runtime image
# ---------------------------------------------------------------------------
FROM debian:bookworm-slim AS runtime

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        tzdata \
        curl \
    && rm -rf /var/lib/apt/lists/* \
    && update-ca-certificates

RUN groupadd --gid 1000 rustred && \
    useradd --uid 1000 --gid rustred --shell /bin/bash --create-home rustred

RUN mkdir -p /data && chown rustred:rustred /data

COPY --from=builder \
    /usr/src/rust-red/target/x86_64-unknown-linux-musl/release/rust-red \
    /usr/local/bin/rust-red

RUN chmod +x /usr/local/bin/rust-red

USER rustred

VOLUME ["/data"]

EXPOSE 1880
EXPOSE 1883

WORKDIR /data

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -sf http://localhost:1880/ || exit 1

ENTRYPOINT ["rust-red"]
CMD ["--flows", "/data/flows.json", "--userDir", "/data"]
