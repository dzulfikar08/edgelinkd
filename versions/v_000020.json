  {
    "finalize": "",
    "func": "// Transform Modbus register array to SQL params\nlet values = msg.payload;\n\n// Registers: [temp_x10, humidity_x10, pressure, status]\nlet temp = (values[0] || 0) / 10;\nlet humidity = (values[1] || 0) / 10;\nlet pressure = values[2] || 0;\nlet status = values[3] || 0;\n\n// Set query and params for postgres-query node\nmsg.query = \"INSERT INTO sensor_readings (temperature, humidity, pressure, status, inserted_at) VALUES ($1, $2, $3, $4, NOW())\";\nmsg.queryParams = [temp, humidity, pressure, status];\n\n// Keep original modbus data for debugging\nmsg.modbus_data = {\n    raw: values,\n    temperature: temp,\n    humidity: humidity,\n    pressure: pressure,\n    status: status\n};\n\nreturn msg;",
